{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Debug tater-tube-server server",
			"type": "go",
			"request": "launch",
			"mode": "auto",
			"program": "${workspaceFolder}/cmd/tater-tube-server",
			"args": ["serve", "--config=${workspaceFolder}//example/config.yaml"],
			"env": {
				"PPROF_PORT": "6060",
				"PORT": "8080",
				"COOKIE_DOMAIN": "localhost",
				"JWT_SECRET": "change-me-to-a-strong-random-secret"
			},
			"cwd": "${workspaceFolder}"
		},
		{
			"name": "Frontend (bun dev)",
			"type": "node",
			"request": "launch",
			"runtimeExecutable": "bun",
			"runtimeArgs": ["run", "dev"],
			"cwd": "${workspaceFolder}/frontend",
			"console": "integratedTerminal",
			"skipFiles": ["<node_internals>/**"]
		}
	],
	"compounds": [
		{
			"name": "Full Stack",
			"configurations": ["Debug tater-tube-server server", "Frontend (bun dev)"]
		}
	]
}
